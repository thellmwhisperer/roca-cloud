{
  "app": ".venv/bin/python infrastructure/app.py",
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/aws-ec2:restrictDefaultSecurityGroup": true,
    "customDomainName": "roca.example.com",
    "certificateArn": "arn:aws:acm:eu-west-2:ACCOUNT_ID:certificate/CERTIFICATE_ID"
  }
}
